# Deterministic Walnut Billing local profile.
# Source through scripts/run_deterministic_billing.sh; the script derives DATABASE_DSN
# and PAYMENT_MOCK_CHECKOUT_BASE_URL from WALNUT_BILLING_TEST_HOME + SERVER_PORT.

SERVER_ENV=dev
SERVER_PORT=8082
WALNUT_BILLING_TEST_HOME=.tmp/deterministic-billing

DATABASE_DRIVER=sqlite

# Local admin keys. local-admin-key is a dev shortcut; support/ops keys exercise scoped permissions.
ADMIN_API_KEYS=local-admin-key
ADMIN_PRINCIPALS_JSON='[{"name":"support","key":"support-key","permissions":["admin.dashboard.read","admin.access_accounts.read","admin.audit.read"]},{"name":"ops","key":"ops-key","permissions":["admin.*"]}]'

RATELIMIT_ENABLED=false
RATELIMIT_MAX_TOKENS=100
RATELIMIT_REFILL_RATE=10

# Deterministic checkout: mock provider only, no external payment network.
PAYMENT_WECHAT_APP_ID=
PAYMENT_WECHAT_MCH_ID=
PAYMENT_WECHAT_SERIAL_NO=
PAYMENT_WECHAT_PRIVATE_KEY=
PAYMENT_WECHAT_API_V3_KEY=
PAYMENT_ALIPAY_APP_ID=
PAYMENT_ALIPAY_PRIVATE_KEY=
PAYMENT_ALIPAY_PUBLIC_KEY=
PAYMENT_CREEM_API_KEY=
PAYMENT_CREEM_WEBHOOK_SECRET=
PAYMENT_CREEM_SANDBOX=true
PAYMENT_CREEM_API_BASE_URL=
PAYMENT_CREEM_SUCCESS_URL=walnut://checkout/success
PAYMENT_CREEM_CANCEL_URL=walnut://checkout/cancel
PAYMENT_CREEM_PRODUCT_MAP_JSON=

# Explicit BYOK SKU fulfillment rules: grant only current advanced software rights.
FULFILLMENT_RULES_JSON='[{"id":"pro_own_ai_monthly:editorial_studio","sku_code":"pro_own_ai_monthly","type":"grant_entitlement","entitlement_id":"editorial.studio","duration":"monthly"},{"id":"pro_own_ai_monthly:cloud_storage","sku_code":"pro_own_ai_monthly","type":"grant_entitlement","entitlement_id":"cloud.storage","duration":"monthly"},{"id":"pro_own_ai_lifetime:editorial_studio","sku_code":"pro_own_ai_lifetime","type":"grant_entitlement","entitlement_id":"editorial.studio","duration":"lifetime"},{"id":"pro_own_ai_lifetime:cloud_storage","sku_code":"pro_own_ai_lifetime","type":"grant_entitlement","entitlement_id":"cloud.storage","duration":"lifetime"}]'

CHECKOUT_RISK_POLICY_ENABLED=true
CHECKOUT_RISK_BLOCK_SEVERITIES=critical,high

ADJUSTMENT_REFUND_WINDOW_DAYS=7
ADJUSTMENT_REFUND_IN_WINDOW_ACTION=auto_refund
ADJUSTMENT_REFUND_OUT_OF_WINDOW_ACTION=manual_review
ADJUSTMENT_LOW_USAGE_POLICY_ENABLED=false
ADJUSTMENT_LOW_USAGE_MAX_CREDITS_USED=0
ADJUSTMENT_LOW_USAGE_ACTION=auto_refund
ADJUSTMENT_HIGH_USAGE_ACTION=manual_review
ADJUSTMENT_DISPUTE_ACTION=auto_refund
ADJUSTMENT_CANCEL_ACTION=keep_current_period

RENEWAL_GRACE_PERIOD_DAYS=3
RENEWAL_EXPIRED_ACTION=expire_grace

ACCESS_SNAPSHOT_SECRET=walnut-dev-access-snapshot-secret
ACCESS_SNAPSHOT_SIGNATURE_ALGORITHM=HS256
ACCESS_SNAPSHOT_KEY_ID=dev
ACCESS_SNAPSHOT_TTL_SECONDS=86400
ACCESS_SNAPSHOT_OFFLINE_GRACE_SECONDS=604800
ACCESS_TRIAL_DURATION_DAYS=14
ACCESS_MAX_DEVICES=2
ACCESS_CLOUD_STORAGE_QUOTA_MB=1024

# Architecture placeholder: cloud storage implementation stays interface-only until provider is chosen.
CLOUD_STORAGE_PROVIDER=
