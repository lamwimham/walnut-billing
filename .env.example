# walnut Billing Server Configuration
# Copy this file to .env and fill in your values

# Server
SERVER_PORT=8082
SERVER_ENV=prod

# Database
DATABASE_DRIVER=sqlite
DATABASE_DSN=./data/walnut_billing.db

# Admin API (comma-separated list of allowed API keys)
ADMIN_API_KEYS=your-secret-key-here

# Rate Limiting
RATELIMIT_ENABLED=true
RATELIMIT_MAX_TOKENS=20
RATELIMIT_REFILL_RATE=2

# WeChat Pay V3 (leave empty to use mock adapter for testing)
PAYMENT_WECHAT_APP_ID=
PAYMENT_WECHAT_MCH_ID=
PAYMENT_WECHAT_SERIAL_NO=
PAYMENT_WECHAT_PRIVATE_KEY=
PAYMENT_WECHAT_API_V3_KEY=

# Alipay (leave empty to use mock adapter for testing)
PAYMENT_ALIPAY_APP_ID=
PAYMENT_ALIPAY_PRIVATE_KEY=
PAYMENT_ALIPAY_PUBLIC_KEY=

# Creem hosted checkout (optional; keep empty until product IDs are configured)
PAYMENT_CREEM_API_KEY=
PAYMENT_CREEM_WEBHOOK_SECRET=
PAYMENT_CREEM_SANDBOX=true
PAYMENT_CREEM_API_BASE_URL=
PAYMENT_CREEM_SUCCESS_URL=
PAYMENT_CREEM_CANCEL_URL=
# PAYMENT_CREEM_PRODUCT_MAP_JSON={"editorial_studio_monthly":"prod_xxx","credits_600":"prod_yyy"}
PAYMENT_CREEM_PRODUCT_MAP_JSON=

# Fulfillment rules (optional JSON array; default rules include editorial_studio_monthly and credits_600)
# FULFILLMENT_RULES_JSON=[{"id":"studio:entitlement","sku_code":"editorial_studio_monthly","type":"grant_entitlement","entitlement_id":"editorial.studio","duration":"monthly"},{"id":"studio:credits","sku_code":"editorial_studio_monthly","type":"grant_credits","credits_amount":600}]
FULFILLMENT_RULES_JSON=
