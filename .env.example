# walnut Billing Server Configuration
# Copy this file to .env and fill in your values

# Server
SERVER_PORT=8082
SERVER_ENV=prod

# Database
DATABASE_DRIVER=sqlite
DATABASE_DSN=./data/walnut_billing.db

# Admin API (comma-separated list of allowed API keys)
# Local/dev shortcut; maps every key to admin.*.
ADMIN_API_KEYS=
# Optional scoped admin principals for closer-to-production tests and production ops.
# ADMIN_PRINCIPALS_JSON='[{"name":"support","key":"support-key","permissions":["admin.dashboard.read","admin.access_accounts.read","admin.audit.read"]}]'
# Rate Limiting
RATELIMIT_ENABLED=true
RATELIMIT_MAX_TOKENS=20
RATELIMIT_REFILL_RATE=2

# WeChat Pay V3 (leave empty to use mock adapter for testing)
PAYMENT_WECHAT_APP_ID=
PAYMENT_WECHAT_MCH_ID=
PAYMENT_WECHAT_SERIAL_NO=
PAYMENT_WECHAT_PRIVATE_KEY=
PAYMENT_WECHAT_API_V3_KEY=

# Alipay (leave empty to use mock adapter for testing)
PAYMENT_ALIPAY_APP_ID=
PAYMENT_ALIPAY_PRIVATE_KEY=
PAYMENT_ALIPAY_PUBLIC_KEY=

# Creem hosted checkout (optional; keep empty until product IDs are configured)
PAYMENT_CREEM_API_KEY=
PAYMENT_CREEM_WEBHOOK_SECRET=
PAYMENT_CREEM_SANDBOX=true
PAYMENT_CREEM_API_BASE_URL=
PAYMENT_CREEM_SUCCESS_URL=
PAYMENT_CREEM_CANCEL_URL=
# PAYMENT_CREEM_PRODUCT_MAP_JSON={"pro_own_ai_monthly":"prod_4MS4IC77zjEobSHExt0gcr","pro_own_ai_lifetime":"prod_lifetime_xxx"}
PAYMENT_CREEM_PRODUCT_MAP_JSON=

# Local mock hosted checkout. Empty defaults to http://localhost:${SERVER_PORT}.
# Set to https://mock.checkout.walnut.local only if local DNS/TLS is configured.
PAYMENT_MOCK_CHECKOUT_BASE_URL=

# Fulfillment rules (optional JSON array; default rules include the Own AI SKUs plus hidden legacy compatibility)
# FULFILLMENT_RULES_JSON=[{"id":"pro_own_ai_monthly:editorial_studio","sku_code":"pro_own_ai_monthly","type":"grant_entitlement","entitlement_id":"editorial.studio","duration":"monthly"},{"id":"pro_own_ai_monthly:cloud_storage","sku_code":"pro_own_ai_monthly","type":"grant_entitlement","entitlement_id":"cloud.storage","duration":"monthly"}]
FULFILLMENT_RULES_JSON=

# Checkout risk policy
CHECKOUT_RISK_POLICY_ENABLED=true
CHECKOUT_RISK_BLOCK_SEVERITIES=critical,high

# Payment adjustment policy
ADJUSTMENT_REFUND_WINDOW_DAYS=7
ADJUSTMENT_REFUND_IN_WINDOW_ACTION=auto_refund
ADJUSTMENT_REFUND_OUT_OF_WINDOW_ACTION=manual_review
ADJUSTMENT_LOW_USAGE_POLICY_ENABLED=false
ADJUSTMENT_LOW_USAGE_MAX_CREDITS_USED=0
ADJUSTMENT_LOW_USAGE_ACTION=auto_refund
ADJUSTMENT_HIGH_USAGE_ACTION=manual_review
ADJUSTMENT_DISPUTE_ACTION=auto_refund
ADJUSTMENT_CANCEL_ACTION=keep_current_period

# Subscription renewal policy
RENEWAL_GRACE_PERIOD_DAYS=3
RENEWAL_EXPIRED_ACTION=expire_grace
