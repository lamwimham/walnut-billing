# walnut Billing Server Configuration
# Copy this file to .env for local development.
# For production, set SERVER_ENV=prod and fill every field required by config.ValidateProduction.

# Server
SERVER_PORT=8082
SERVER_ENV=dev

# Database
DATABASE_DRIVER=sqlite
DATABASE_DSN=./walnut_billing_local.db
# dev defaults to auto; production must use versioned so applied migrations are recorded.
DATABASE_MIGRATION_MODE=auto

# HTTP browser boundary
# Production requires explicit HTTPS browser origins and enabled security headers.
HTTP_CORS_ALLOWED_ORIGINS=
HTTP_SECURITY_HEADERS_ENABLED=true
HTTP_SECURITY_HEADERS_HSTS_MAX_AGE_SECONDS=31536000

# Admin API (comma-separated list of allowed API keys)
# Local/dev shortcut; maps every key to admin.*.
ADMIN_API_KEYS=
# Optional scoped admin principals for closer-to-production tests and production ops.
# In prod, prefer scoped principals over ADMIN_API_KEYS.
# ADMIN_PRINCIPALS_JSON='[{"name":"support","key":"support-key","permissions":["admin.dashboard.read","admin.access_accounts.read","admin.users.read","admin.orders.read","admin.subscriptions.read","admin.cloud_storage.read","admin.audit.read"]}]'
# Rate Limiting
RATELIMIT_ENABLED=true
RATELIMIT_MAX_TOKENS=20
RATELIMIT_REFILL_RATE=2

# WeChat Pay V3 (leave empty to use mock adapter for testing)
PAYMENT_WECHAT_APP_ID=
PAYMENT_WECHAT_MCH_ID=
PAYMENT_WECHAT_SERIAL_NO=
PAYMENT_WECHAT_PRIVATE_KEY=
PAYMENT_WECHAT_API_V3_KEY=

# Alipay (leave empty to use mock adapter for testing)
PAYMENT_ALIPAY_APP_ID=
PAYMENT_ALIPAY_PRIVATE_KEY=
PAYMENT_ALIPAY_PUBLIC_KEY=

# Creem hosted checkout. Test mode uses sandbox=true; prod must use live credentials and sandbox=false.
PAYMENT_CREEM_API_KEY=
PAYMENT_CREEM_WEBHOOK_SECRET=
PAYMENT_CREEM_SANDBOX=true
PAYMENT_CREEM_API_BASE_URL=
PAYMENT_CREEM_SUCCESS_URL=walnut://checkout/success
PAYMENT_CREEM_CANCEL_URL=walnut://checkout/cancel
# PAYMENT_CREEM_PRODUCT_MAP_JSON={"pro_own_ai_monthly":"prod_4MS4IC77zjEobSHExt0gcr","pro_own_ai_lifetime":"prod_lifetime_xxx"}
PAYMENT_CREEM_PRODUCT_MAP_JSON=

# Local mock hosted checkout. Empty defaults to http://localhost:${SERVER_PORT}.
# Set to https://mock.checkout.walnut.local only if local DNS/TLS is configured.
PAYMENT_MOCK_CHECKOUT_BASE_URL=

# Fulfillment rules (optional JSON array; default rules include the Own AI SKUs plus hidden legacy compatibility)
# FULFILLMENT_RULES_JSON=[{"id":"pro_own_ai_monthly:editorial_studio","sku_code":"pro_own_ai_monthly","type":"grant_entitlement","entitlement_id":"editorial.studio","duration":"monthly"},{"id":"pro_own_ai_monthly:cloud_storage","sku_code":"pro_own_ai_monthly","type":"grant_entitlement","entitlement_id":"cloud.storage","duration":"monthly"}]
FULFILLMENT_RULES_JSON=

# Checkout risk policy
CHECKOUT_RISK_POLICY_ENABLED=true
CHECKOUT_RISK_BLOCK_SEVERITIES=critical,high
# Production fail-fast requires every checkout success/cancel redirect origin or app scheme here.
CHECKOUT_REDIRECT_ALLOWLIST=

# Payment adjustment policy
ADJUSTMENT_REFUND_WINDOW_DAYS=7
ADJUSTMENT_REFUND_IN_WINDOW_ACTION=auto_refund
ADJUSTMENT_REFUND_OUT_OF_WINDOW_ACTION=manual_review
ADJUSTMENT_LOW_USAGE_POLICY_ENABLED=false
ADJUSTMENT_LOW_USAGE_MAX_CREDITS_USED=0
ADJUSTMENT_LOW_USAGE_ACTION=auto_refund
ADJUSTMENT_HIGH_USAGE_ACTION=manual_review
ADJUSTMENT_DISPUTE_ACTION=auto_refund
ADJUSTMENT_CANCEL_ACTION=keep_current_period

# Subscription renewal policy
RENEWAL_GRACE_PERIOD_DAYS=3
RENEWAL_EXPIRED_ACTION=expire_grace

# Access control and email login/recovery challenges
ACCESS_SNAPSHOT_SIGNATURE_ALGORITHM=HS256
ACCESS_SNAPSHOT_SECRET=walnut-dev-access-snapshot-secret
ACCESS_SNAPSHOT_PRIVATE_KEY=
ACCESS_SNAPSHOT_KEY_ID=dev
ACCESS_SNAPSHOT_TTL_SECONDS=86400
ACCESS_SNAPSHOT_OFFLINE_GRACE_SECONDS=604800
ACCESS_MAX_DEVICES=2
ACCESS_CLOUD_STORAGE_QUOTA_MB=1024
# Plan-specific cloud quotas inherit ACCESS_CLOUD_STORAGE_QUOTA_MB when set to 0.
ACCESS_CLOUD_STORAGE_TRIAL_QUOTA_MB=0
ACCESS_CLOUD_STORAGE_MONTHLY_QUOTA_MB=0
ACCESS_CLOUD_STORAGE_LIFETIME_QUOTA_MB=0
ACCESS_TRIAL_DURATION_DAYS=14
ACCESS_LOGIN_CHALLENGE_TTL_SECONDS=600
ACCESS_LOGIN_CHALLENGE_MAX_ATTEMPTS=5
ACCESS_LOGIN_CHALLENGE_RATE_LIMIT_WINDOW_SECONDS=600
ACCESS_LOGIN_CHALLENGE_MAX_CREATES_PER_EMAIL=5
ACCESS_LOGIN_CHALLENGE_MAX_CREATES_PER_IP=20
# dev returns dev_token for local testing; prod must not use dev delivery or the dev secret.
ACCESS_LOGIN_CHALLENGE_DELIVERY=dev
ACCESS_LOGIN_CHALLENGE_SECRET=walnut-dev-login-challenge-secret
